{
	"name": "@iefa/assignment-selection",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bunx --bun vite dev",
		"build": "bunx --bun vite build",
		"serve": "bunx --bun vite preview",
		"format": "biome format",
		"lint": "biome lint",
		"check": "biome check",
		"typecheck": "tsgo --noEmit",
		"validate-env": "bun run src/env.ts",
		"test": "ASSIGNMENT_SELECTION_RUN_INTEGRATION=false vitest run --config vitest.config.ts",
		"test:integration": "ASSIGNMENT_SELECTION_RUN_INTEGRATION=true ASSIGNMENT_SELECTION_INTEGRATION_REQUIRED=true vitest run --config vitest.config.ts"
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0",
		"@iefa/database": "workspace:*",
