		"@typescript/native-preview": "^7.0.0-dev.20260622.1",
		"@vitejs/plugin-react": "^6.0.3",
		"babel-plugin-react-compiler": "^1.0.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.9"
	}
