# sucont — variáveis de ambiente
# @generateTypes(lang=ts, path=env.d.ts)
# @defaultSensitive=true
# ---

# URL pública do projeto Supabase (exposta ao cliente via VITE_)
# @required
# @type=string(startsWith=https)
# @public
VITE_SUCONT_SUPABASE_URL=

# Chave publicável do Supabase — anon key (exposta ao cliente via VITE_)
# @required
# @public
VITE_SUCONT_SUPABASE_PUBLISHABLE_KEY=

# Service role key do Supabase — somente servidor, nunca exposta ao cliente
# @required
# @sensitive
SUCONT_SUPABASE_SECRET_KEY=

# === IA — Oráculo SUCONT (fluxo NÃO essencial) ===
# Ausentes → as telas de chat/documentação de IA respondem com erro amigável e
# não bloqueiam o boot. Lidas por @iefa/ai-provider (prefixo SUCONT).
# Providers válidos: groq | nvidia | openrouter | gemini | anthropic | ollama | bedrock.
# bedrock: model = id do modelo ou do inference profile; autentica pela cadeia de
#   credenciais AWS (task role em prod, profile em dev); região vem de
#   SUCONT_AI_REGION, senão AWS_REGION / AWS_DEFAULT_REGION.

# @optional (sem isto: telas de IA ficam indisponíveis)
SUCONT_AI_PROVIDER=
# @optional
SUCONT_AI_MODEL=
# @optional (não usar com bedrock/ollama)
# @sensitive
SUCONT_AI_API_KEY=
# @optional (só bedrock; padrão: AWS_REGION / AWS_DEFAULT_REGION)
SUCONT_AI_REGION=
