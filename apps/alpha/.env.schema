# ai / RAG — variáveis de ambiente
# @generateTypes(lang=ts, path=env.d.ts)
# @defaultSensitive=false
# ---

# ── Supabase ──────────────────────────────────────────────────────────────────

# @required
# @type=string(startsWith=https)
SUPABASE_URL=

# @required
# @sensitive
SUPABASE_SERVICE_ROLE_KEY=

# String de conexão PostgreSQL direta (para LangGraph checkpointer)
# @required
# @sensitive
DATABASE_URL=

# ── NVIDIA NIM — LLM + Embeddings + Reranker ──────────────────────────────────

# @required
# @sensitive
NVIDIA_API_KEY=

# @required
# @type=string(startsWith=https)
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ── Modelos ───────────────────────────────────────────────────────────────────

# @optional
LLM_MODEL=openai/gpt-oss-120b

# @optional
EMB_MODEL=baai/bge-m3

# Prefixo aplicado à query antes de gerar embedding
# @optional
EMB_QUERY_PREFIX=Represent this sentence for searching relevant passages:

# @optional
EMB_TRUNCATE=END

# @optional
# @type=boolean
EMB_NORMALIZE=true

# @optional
# @type=number
EMB_BATCH_SIZE=128

# ── Reranker ──────────────────────────────────────────────────────────────────

# Multilingual PT suportado — MIRACL 26 langs
# @optional
NVIDIA_RERANK_MODEL=nvidia/llama-3.2-nv-rerankqa-1b-v2

# @optional
# @type=number
RERANK_TOP_N=5

# Score mínimo do reranker para incluir chunk
# @optional
# @type=number
RERANK_THRESHOLD=0.45

# ── Hiperparâmetros de busca híbrida ─────────────────────────────────────────

# @optional
# @type=number
K_SEM=4

# @optional
# @type=number
K_KEYWORD=6

# @optional
# @type=number
RRF_K=60

# ── Servidor ──────────────────────────────────────────────────────────────────

# @optional
# @type=number
PORT=3001

# ── LangSmith (observabilidade opcional) ─────────────────────────────────────

# @optional
# @sensitive
LANGCHAIN_API_KEY=

# @optional
# @type=boolean
LANGCHAIN_TRACING_V2=true

# @optional
LANGCHAIN_PROJECT=alpha-aci
