# sisub — variáveis de ambiente
# @generateTypes(lang=ts, path=env.d.ts)
# @defaultSensitive=true
# ---

# === Observability — Grafana Faro (frontend) / OpenTelemetry (backend) ===
# Todas opcionais em runtime: ausentes → no-op silencioso, não quebram o boot.

# Collector URL do Grafana Faro — exposto ao cliente via VITE_ (não é secret).
# Ausente → Faro não inicializa (sem captura de erro JS/Web Vitals).
# @optional
# @public
VITE_FARO_COLLECTOR_URL=

# Nome da app no Faro/Frontend Observability (padrão: sisub).
# @optional
# @public
VITE_FARO_APP_NAME=

# Override do environment reportado ao Faro (padrão: import.meta.env.MODE).
# O painel filtra environment=production por padrão (sem opção na UI) — setar
# "production" em dev torna os eventos visíveis no Overview.
# @optional
# @public
VITE_FARO_ENVIRONMENT=

# Endpoint OTLP do Grafana Cloud (Tempo) — somente servidor.
# Ausente → OTel não registra provider (sem spans de erro server-side).
# @optional
# @sensitive
OTEL_EXPORTER_OTLP_ENDPOINT=

# Headers OTLP — Basic Auth: Authorization=Basic base64("<instanceID>:<token>").
# @optional
# @sensitive
OTEL_EXPORTER_OTLP_HEADERS=

# service.name reportado nos spans (padrão: sisub).
# @optional
OTEL_SERVICE_NAME=

# API key de upload de sourcemaps do Faro — usada SÓ no build (vite.config.ts),
# não em runtime. Ausente → build não gera/envia maps (stacks ofuscadas no Grafana).
# Scopes: sourcemaps:read, sourcemaps:write, sourcemaps:delete.
# @optional
# @sensitive
FARO_SOURCEMAP_API_KEY=

# URL pública do projeto Supabase (exposta ao cliente via VITE_)
# @required
# @type=string(startsWith=https)
# @public
VITE_SISUB_SUPABASE_URL=

# Chave publicável do Supabase — anon key (exposta ao cliente via VITE_)
# @required
# @public
VITE_SISUB_SUPABASE_PUBLISHABLE_KEY=

# Service role key do Supabase — somente servidor, nunca exposta ao cliente
# @required
# @sensitive
SISUB_SUPABASE_SECRET_KEY=

# Conexão Postgres direta (Drizzle ORM) — query layer do @iefa/sisub-domain via getDb().
# Use o transaction pooler (porta 6543) com prepare:false. Formato:
#   postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
# A senha é a DB password do projeto (Settings → Database), NÃO a SISUB_SUPABASE_SECRET_KEY.
# Conecta pelo role do projeto → bypassa RLS; a autorização segue nos guards PBAC do domínio.
# @required
# @sensitive
SISUB_DATABASE_URL=

# Secret compartilhado com a IEFA API (x-admin-secret)
# @required
# @sensitive
ADMIN_SECRET=

# URL base da IEFA API — somente servidor
# @optional (padrão: https://iefa-api.fly.dev)
IEFA_API_BASE_URL=

# URL pública da aplicação — usada em meta tags canônicas (og:url, twitter:url)
# @public
# @optional (padrão: vazio — og:url fica relativo em dev)
VITE_PUBLIC_URL=

# URL base do Projeto α — somente servidor
# @optional (padrão: https://iefa-ai.fly.dev)
# @sensitive
ALPHA_API_BASE_URL=

# === IA — Assistentes de chat (fluxo NÃO essencial) ===
# Ausentes → as telas de chat mostram "Em breve" e os endpoints respondem 503.
# NÃO bloqueiam o deploy. Configurados via prefixo, lidos por @iefa/ai-provider.
# Providers válidos: groq | nvidia | openrouter | gemini | anthropic | ollama.
# api_key é exigida para todos exceto ollama.

# Chat IA dos módulos (global/kitchen/unit/local-analytics)
# @optional (sem isto: telas de chat de módulo ficam "Em breve")
MODULE_CHAT_AI_PROVIDER=
# @optional
MODULE_CHAT_AI_MODEL=
# @optional
# @sensitive
MODULE_CHAT_AI_API_KEY=

# Assistente IA de Analytics
# @optional (sem isto: /analytics/chat fica "Em breve")
ANALYTICS_AI_PROVIDER=
# @optional
ANALYTICS_AI_MODEL=
# @optional
# @sensitive
ANALYTICS_AI_API_KEY=

# === E2E (Playwright) ===
# Credenciais do usuário de teste dedicado — NUNCA usar conta real
# Usado exclusivamente em testes E2E locais e no CI

# Email do usuário de teste E2E
# @optional (requerido para rodar testes E2E)
# @sensitive
E2E_TEST_USER_EMAIL=

# Senha do usuário de teste E2E
# @optional (requerido para rodar testes E2E)
# @sensitive
E2E_TEST_USER_PASSWORD=
