{
    "include": ["**/*.ts", "**/*.tsx"],
    "compilerOptions": {
        "target": "ESNext",
        "jsx": "react-jsx",
        "module": "ESNext",
        "lib": ["ESNext", "DOM", "DOM.Iterable"],
        "types": ["vite/client"],

        /* Bundler mode */
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": false,
        "noEmit": true,

        /* Linting */
        "skipLibCheck": true,
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        "noUncheckedSideEffectImports": true,
        "paths": {
            "@/*": ["./src/*"],
            "@rolldown/plugin-babel": ["./node_modules/@rolldown/plugin-babel/dist/index.d.mts"]
        }
    }
}
