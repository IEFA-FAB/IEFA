{
    "name": "@iefa/sisub",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "bunx --bun vite dev",
        "build": "bunx --bun vite build",
        "serve": "bunx --bun vite preview",
        "format": "biome format",
        "lint": "biome lint",
        "check": "biome check",
        "typecheck": "tsgo --noEmit",
        "validate-env": "bun run src/lib/env.ts",
        "test": "bun run test:unit",
        "test:unit": "SISUB_RUN_INTEGRATION=false vitest run --config vitest.config.ts",
        "test:integration": "SISUB_RUN_INTEGRATION=true SISUB_INTEGRATION_REQUIRED=true vitest run --config vitest.config.ts",
        "test:e2e": "bunx playwright test",
        "test:e2e:ci": "bunx playwright test --project=chromium e2e/tests/smoke.spec.ts e2e/tests/auth.spec.ts e2e/tests/navigation.spec.ts",
        "test:e2e:full": "ALL_BROWSERS=true bunx playwright test",
        "test:e2e:ui": "bunx playwright test --ui"
    },
    "dependencies": {
        "@base-ui/react": "^1.3.0",
        "@iefa/ai-provider": "workspace:*",
        "@iefa/alpha-client": "workspace:*",
        "@iefa/database": "workspace:*",
        "@iefa/hono-client": "workspace:*",
        "@iefa/pbac": "workspace:*",
        "@iefa/sisub-domain": "workspace:*",
"@paper-design/shaders-react": "^0.0.76",
        "@supabase/ssr": "^0.10.2",
        "@supabase/supabase-js": "^2.103.0",
        "@tailwindcss/vite": "^4.2.2",
        "@tanstack/hotkeys": "^0.7.1",
        "@tanstack/react-form": "^1.28.6",
        "@tanstack/react-hotkeys": "^0.9.1",
        "@tanstack/react-query": "^5.100.10",
