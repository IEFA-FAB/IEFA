{
  "name": "iefa",
  "private": true,
  "packageManager": "bun@1.3.6",
  "overrides": {
    "react": "^19.2",
    "react-dom": "^19.2"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "validate-env": "turbo validate-env",
    "sisub:dev": "bun --cwd ./apps/sisub dev",
    "portal:dev": "bun --cwd ./apps/iefa dev",
    "api:dev": "bun --cwd ./apps/api dev",
    "docs:dev": "bun --cwd ./apps/docs dev",
    "format": "biome format --write .",
    "fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "turbo": "^2.8.10"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
