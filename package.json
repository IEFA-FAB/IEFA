{
  "name": "iefa",
  "private": true,
  "packageManager": "bun@1.3.10",
  "overrides": {
    "react": "^19.2",
    "react-dom": "^19.2",
    "@tanstack/query-core": "5.100.10"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "sisub:dev": "bun --cwd ./apps/sisub dev",
    "sisub:test:e2e": "turbo run test:e2e --filter=@iefa/sisub",
    "sisub-mcp:dev": "bun --cwd ./apps/sisub-mcp dev",
    "sisub-mcp:start": "bun --cwd ./apps/sisub-mcp start",
    "portal:dev": "bun --cwd ./apps/portal dev",
    "api:dev": "bun --cwd ./apps/api dev",
    "forms:dev": "bun --cwd ./apps/forms dev",
    "5s:dev": "VITE_APP_TENANT=cinco-s bun --cwd ./apps/forms dev -- --port 3002",
    "docs:dev": "bun --cwd ./apps/docs dev",
    "format": "biome format --write .",
    "format:check": "biome format . --write",
    "fix": "biome check --write .",
    "check": "biome check . && bun run typecheck",
    "ci": "bun run lint && bun run typecheck",
    "clean": "bunx turbo run clean && rm -rf node_modules .turbo",
    "clean:cache": "rm -rf .turbo node_modules/.cache",
    "knip": "knip",
    "upgrade": "bun update --latest",
    "commit": "bun run format:check && bunx turbo run lint typecheck && cz",
    "prepare": "husky",
    "quicksave": "git add . && git commit -m \"chore(root): wip unstable\""
  },
  "config": {
    "commitizen": {
      "path": "cz-git"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "commitizen": "^4.3.1",
    "cz-git": "^1.13.1",
    "husky": "^9.1.7",
    "knip": "^6.14.1",
    "turbo": "^2.9.14",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@tanstack/cli": "^0.68.0",
    "greptile": "^2.4.0",
    "react-doctor": "^0.1.6",
    "root": "tanstack/cli"
  }
}
