{
  "name": "iefa",
  "private": true,
  "packageManager": "bun@1.3.10",
  "overrides": {
    "react": "^19.2",
    "react-dom": "^19.2"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck --parallel",
    "lint": "turbo lint --parallel",
    "test": "turbo test --parallel",
    "sisub:dev": "bun --cwd ./apps/sisub dev",
    "portal:dev": "bun --cwd ./apps/portal dev",
    "api:dev": "bun --cwd ./apps/api dev",
    "docs:dev": "bun --cwd ./apps/docs dev",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "fix": "biome check --write .",
    "check": "biome check . && bun run typecheck",
    "ci": "bun run lint && bun run typecheck",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "clean:cache": "rm -rf .turbo node_modules/.cache",
    "knip": "knip",
    "upgrade": "bun update --latest",
    "commit": "cz",
    "prepare": "husky"
  },
  "config": {
    "commitizen": {
      "path": "cz-git"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "husky": "^9.1.7",
    "knip": "^5.88.1",
    "turbo": "^2.8.20"
  },
  "workspaces": [
    "apps/*"
  ]
}
