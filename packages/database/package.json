{
  "name": "@iefa/database",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./generated": "./src/generated.ts",
    "./sisub": "./src/sisub.ts",
    "./compras-gov": "./src/compras-gov.ts",
    "./portal": "./src/portal.ts",
    "./journal": "./src/journal.ts",
    "./forms": "./src/forms.ts",
    "./rumaer": "./src/rumaer.ts",
    "./assignment-selection": "./src/assignment-selection.ts",
    "./drizzle/sisub": "./drizzle/sisub.ts"
  },
  "scripts": {
    "generate": "bun run db:types",
    "db:link": "bunx supabase link --project-ref jgigqdpdjgnnuwajtayh",
    "db:types": "bunx supabase gen types typescript --project-id jgigqdpdjgnnuwajtayh --schema sisub,iefa,journal,forms,rumaer,core,access_control,kitchen,procurement,finance,compras_gov_integration,nutrition_reference,inventory,siafi_integration,gs1_integration,assignment_selection > ./src/generated.ts",
    "db:push": "bunx supabase db push",
    "db:pull": "bunx supabase db pull --schema sisub,iefa,journal,forms,rumaer,core,access_control,kitchen,procurement,finance,compras_gov_integration,nutrition_reference,inventory,siafi_integration,gs1_integration,assignment_selection",
    "db:diff": "bunx supabase db diff --schema sisub,iefa,journal,forms,rumaer,core,access_control,kitchen,procurement,finance,compras_gov_integration,nutrition_reference,inventory,siafi_integration,gs1_integration,assignment_selection",
    "db:reset": "bunx supabase db reset",
    "db:migrations": "bunx supabase migration list",
    "db:repair:applied": "bunx supabase migration repair --status applied",
    "db:repair:reverted": "bunx supabase migration repair --status reverted",
    "db:drizzle:pull": "bunx drizzle-kit pull && bun run scripts/patch-drizzle-pull.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "supabase": "2.107.0"
  }
}
