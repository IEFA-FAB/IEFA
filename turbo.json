{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".output/**", "dist/**", "build/**"],
      "inputs": [
        "src/**",
        "package.json",
        "tsconfig.json",
        "turbo.json",
        "vite.config.*",
        "app.config.*",
        "vinxi.config.*"
      ]
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    },
    "test": {
      "outputs": [],
      "env": ["API_SUPABASE_URL", "API_SUPABASE_SERVICE_ROLE_KEY", "ADMIN_SECRET"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
