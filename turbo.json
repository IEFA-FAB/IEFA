{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".output/**", "dist/**", "build/**"],
      "inputs": [
        "src/**",
        "pages/**",
        "content/**",
        "components/**",
        "lib/**",
        "styles/**",
        "package.json",
        "tsconfig.json",
        "turbo.json",
        "vite.config.*",
        "waku.config.*",
        "source.config.*",
        "app.config.*",
        "vinxi.config.*"
      ]
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    },
    "test": {
      "outputs": [],
      "env": [
        "API_SUPABASE_URL",
        "API_SUPABASE_SERVICE_ROLE_KEY",
        "ADMIN_SECRET",
        "SISUB_RUN_INTEGRATION",
        "SISUB_INTEGRATION_REQUIRED",
        "VITE_SISUB_SUPABASE_URL",
        "VITE_SISUB_SUPABASE_PUBLISHABLE_KEY",
        "SISUB_SUPABASE_SECRET_KEY"
      ]
    },
    "test:unit": {
      "outputs": []
    },
    "test:integration": {
      "outputs": [],
      "env": [
        "SISUB_RUN_INTEGRATION",
        "SISUB_INTEGRATION_REQUIRED",
        "VITE_SISUB_SUPABASE_URL",
        "VITE_SISUB_SUPABASE_PUBLISHABLE_KEY",
        "SISUB_SUPABASE_SECRET_KEY"
      ]
    },
    "test:e2e": {
      "outputs": ["playwright-report/**", "test-results/**"],
      "env": [
        "VITE_SISUB_SUPABASE_URL",
        "VITE_SISUB_SUPABASE_PUBLISHABLE_KEY",
        "SISUB_SUPABASE_SECRET_KEY",
        "E2E_TEST_USER_EMAIL",
        "E2E_TEST_USER_PASSWORD"
      ]
    },
    "test:e2e:ci": {
      "outputs": ["playwright-report/**", "test-results/**"],
      "env": [
        "CI",
        "VITE_SISUB_SUPABASE_URL",
        "VITE_SISUB_SUPABASE_PUBLISHABLE_KEY",
        "SISUB_SUPABASE_SECRET_KEY",
        "E2E_TEST_USER_EMAIL",
        "E2E_TEST_USER_PASSWORD"
      ]
    },
    "test:e2e:full": {
      "outputs": ["playwright-report/**", "test-results/**"],
      "env": [
        "CI",
        "ALL_BROWSERS",
        "VITE_SISUB_SUPABASE_URL",
        "VITE_SISUB_SUPABASE_PUBLISHABLE_KEY",
        "SISUB_SUPABASE_SECRET_KEY",
        "E2E_TEST_USER_EMAIL",
        "E2E_TEST_USER_PASSWORD"
      ]
    },
    "generate": {
      "cache": false,
      "outputs": ["src/types.gen.ts", "src/generated.ts"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "@iefa/sisub-mcp#build": {
      "outputs": ["dist/**"]
    }
  }
}
