# Copy to terraform.tfvars. Apply infra/foundation first, then this stack.
# state_bucket comes from the infra/bootstrap output (state_bucket_name).
state_bucket         = "CHANGE_ME_FROM_INFRA_BOOTSTRAP_OUTPUT"
state_region         = "sa-east-1"
foundation_state_key = "foundation/prod/terraform.tfstate"
aws_region           = "sa-east-1"

service_name      = "portal"
docker_target     = "portal"
container_port    = 3000
cpu               = 256
memory            = 512
health_check_path = "/health"
listener_priority = 100

environment_variables = {
  NODE_ENV = "production"
  PORT     = "3000"
}

secret_names = [
  "VITE_IEFA_SUPABASE_URL",
  "VITE_IEFA_SUPABASE_PUBLISHABLE_KEY",
  "IEFA_SUPABASE_SECRET_KEY",
]

# Host-based routing on the shared ALB (requires a certificate on the foundation).

# User-facing SSR app: two tasks so a Spot reclamation never leaves the portal down.
# Internal/low-traffic services stay on the module default of 1.
desired_count = 2

# Alternative to a second Spot task: pin one on-demand task instead (≈2x the
# hourly rate of Spot, but immune to capacity reclamation).
# fargate_on_demand_base = 1

hosts = ["portal.iefa.com.br"]
