# Copy to terraform.tfvars. Apply infra/foundation first, then this stack.
# state_bucket comes from the infra/bootstrap output (state_bucket_name).
state_bucket         = "CHANGE_ME_FROM_INFRA_BOOTSTRAP_OUTPUT"
state_region         = "sa-east-1"
foundation_state_key = "foundation/prod/terraform.tfstate"
aws_region           = "sa-east-1"

service_name      = "sisub-mcp"
docker_target     = "sisub-mcp"
container_port    = 3000
cpu               = 256
memory            = 512
health_check_path = "/health"
listener_priority = 180

environment_variables = {
  NODE_ENV      = "production"
  MCP_TRANSPORT = "http"
  MCP_PORT      = "3000"
}

secret_names = [
  "SISUB_DATABASE_URL",
  "VITE_SISUB_SUPABASE_URL",
  "SISUB_SUPABASE_SECRET_KEY",
  "SISUB_SUPABASE_ANON_KEY",
]

# Scaled to zero: this MCP server served 5 requests in 14 days, so paying for an
# always-on task (Fargate hours + a public IPv4) buys nothing. It is on-demand
# infrastructure — raise to 1 when someone actually needs it:
#
#   aws ecs update-service --cluster iefa-prod-cluster --service sisub-mcp --desired-count 1
#
# Migrating it to Lambda was considered and rejected: MCP sessions live in an
# in-memory Map and StreamableHTTPServerTransport uses SSE, which ALB Lambda
# targets cannot stream. Not worth the redesign at this usage.
desired_count = 0

hosts = ["sisub-mcp.iefa.com.br"]
