# Copy to terraform.tfvars. Apply infra/foundation first, then this stack.
# state_bucket comes from the infra/bootstrap output (state_bucket_name).
state_bucket         = "CHANGE_ME_FROM_INFRA_BOOTSTRAP_OUTPUT"
state_region         = "sa-east-1"
foundation_state_key = "foundation/prod/terraform.tfstate"
aws_region           = "sa-east-1"

service_name      = "api"
docker_target     = "api"
container_port    = 3000
cpu               = 256
memory            = 512
health_check_path = "/health"
listener_priority = 120

environment_variables = {
  NODE_ENV = "production"
  API_PORT = "3000"
}

# ADMIN_SECRET is required by the nutrition sync admin endpoints (POST
# /api/admin/nutrition/sync). Store it in the api secret JSON.
secret_names = [
  "API_SUPABASE_URL",
  "API_SUPABASE_SERVICE_ROLE_KEY",
  "ADMIN_SECRET",
]


hosts = ["api.iefa.com.br"]
