      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/sisub": {
      "entry": ["src/client.tsx", "src/ssr.tsx", "src/router.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/ai": {
      "entry": ["src/index.ts"],
